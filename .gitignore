.DS_Store
__pycache__/
*.py[cod]
.venv/
.venv-*/

# Keep the programmed factory image, not compiler intermediates.
firmware/build/*
!firmware/build/swansong-usb.hex

# The local Microchip framework bundle is large; retain only headers used by
# this firmware target (see the checked-in dependency list in the Makefile).
firmware/include/*
!firmware/include/Compiler.h
!firmware/include/GenericTypeDefs.h
!firmware/include/USB/
firmware/include/USB/*
!firmware/include/USB/usb.h
!firmware/include/USB/usb_ch9.h
!firmware/include/USB/usb_common.h
!firmware/include/USB/usb_device.h
!firmware/include/USB/usb_function_hid.h
!firmware/include/USB/usb_hal.h
!firmware/include/USB/usb_hal_pic16f1.h

# Local scratch outputs; reviewed release renders are explicitly tracked.
review-renders/bottom.png
review-renders/top.png
review-renders/bottom-standard.png
review-renders/top-standard.png
review-renders/bottom-edge-clearance.png
review-renders/top-edge-clearance.png
review-renders/bottom-final.png
review-renders/top-final.png
